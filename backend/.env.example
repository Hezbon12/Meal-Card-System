# ─────────────────────────────────────────────────────────────
# ShuleMeal Cards — Backend Environment Variables
# Copy this file to .env and fill in all values before deploying.
# ─────────────────────────────────────────────────────────────

# REQUIRED — Generate with: npm run generate-secret
JWT_SECRET=

# REQUIRED — Choose a strong password (uppercase, number, symbol)
SUPER_ADMIN_PASSWORD=

# REQUIRED in production — Must be your exact domain, NOT wildcard.
# The server will refuse to start in production if this is set to *.
# Example: https://shulemeal.yourdomain.com
# Multiple origins: https://app.yourdomain.com,https://admin.yourdomain.com
ALLOWED_ORIGIN=*

# SendGrid — for signup notification emails (optional but recommended)
# Get your API key at: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=
# The email address YOU want to receive signup notifications
NOTIFY_EMAIL=
# A verified sender email in your SendGrid account
FROM_EMAIL=

# Path to SQLite database file (default: ./database.sqlite)
DB_PATH=./database.sqlite

# Port the backend listens on (default: 5000)
PORT=5000

# Set to 'production' on your server.
# In production mode:
#   - JWT_SECRET must be set or the server crashes
#   - SUPER_ADMIN_PASSWORD must be set or the server crashes
#   - ALLOWED_ORIGIN must not be '*' or the server crashes
NODE_ENV=development

# ─────────────────────────────────────────────────────────────
# Node.js version note:
# This app uses better-sqlite3 which requires a prebuilt native binary.
# Recommended: Node.js 20 LTS (has prebuilt binaries for all platforms).
# After npm install, run: node install-better-sqlite3.js
# if you see "Could not locate the bindings file" errors.
# ─────────────────────────────────────────────────────────────
