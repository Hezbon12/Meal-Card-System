# ─────────────────────────────────────────────────────────────
# ShuleMeal Cards — Backend Environment Variables
# Copy this file to .env and fill in all values before deploying.
# ─────────────────────────────────────────────────────────────

# REQUIRED — Generate with: npm run generate-secret
JWT_SECRET=

# REQUIRED — Choose a strong password (uppercase, number, symbol)
SUPER_ADMIN_PASSWORD=

# REQUIRED — 64-char hex key for encrypting student data at rest
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: Never change this after data has been stored — it will corrupt existing records.
ENCRYPTION_KEY=

# REQUIRED in production — Must be your exact domain, NOT wildcard.
# The server will refuse to start in production if this is set to *.
# Example: https://shulemeal.yourdomain.com
ALLOWED_ORIGIN=*

# REQUIRED — PostgreSQL connection string
# Local:      postgresql://user:password@localhost:5432/shulemeal
# Supabase:   postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
# Railway:    (copy from Railway dashboard)
# Render:     (copy from Render dashboard)
DATABASE_URL=postgresql://postgres:password@localhost:5432/shulemeal

# SendGrid — for signup notification emails (optional but recommended)
SENDGRID_API_KEY=
NOTIFY_EMAIL=
FROM_EMAIL=

# Port the backend listens on (default: 5000)
PORT=5000

# Set to 'production' on your server.
NODE_ENV=development
