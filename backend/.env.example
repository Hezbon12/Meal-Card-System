# Copy this to .env and fill in real values before deploying

# REQUIRED in production — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# REQUIRED in production — choose a strong password
SUPER_ADMIN_PASSWORD=

# Your deployed frontend domain (comma-separated if multiple)
# Example: https://shulemeal.yourdomain.com
ALLOWED_ORIGIN=*

# SendGrid — for signup notification emails
# Get your API key at: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=
# The email address YOU want to receive signup notifications
NOTIFY_EMAIL=
# A verified sender email in your SendGrid account
FROM_EMAIL=

# Path to SQLite database file
DB_PATH=./database.sqlite

# Port the backend listens on
PORT=5000

# Set to 'production' on your server — enables startup checks that crash if secrets are missing
NODE_ENV=development
